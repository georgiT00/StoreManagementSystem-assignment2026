@model UserInputModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="container mx-auto px-4 py-6">
    <h1 class="text-3xl font-bold mb-6 text-gray-800">Edit User</h1>

    <form asp-area="Admin" asp-controller="UserManager" asp-action="Edit" method="post" class="space-y-6 bg-white py-2 px-4 rounded-lg shadow-md">
        <input type="hidden" asp-for="Id" />

        <div>
            <label asp-for="FirstName" class="block font-medium text-gray-700 text-xl">First Name</label>
            <input asp-for="FirstName" class="mt-1 block w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" />
            <span asp-validation-for="FirstName" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="LastName" class="block font-medium text-gray-700 text-xl">Last Name</label>
            <input asp-for="LastName" class="mt-1 block w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" />
            <span asp-validation-for="LastName" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="UserName" class="block font-medium text-gray-700 text-xl">Username</label>
            <input asp-for="UserName" class="mt-1 block w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" />
            <span asp-validation-for="UserName" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Email" class="block font-medium text-gray-700 text-xl">Email</label>
            <input asp-for="Email" type="email" class="mt-1 block w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" />
            <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="PhoneNumber" class="block font-medium text-gray-700 text-xl">Phone number (optional)</label>
            <input asp-for="PhoneNumber" type="text" class="mt-1 block w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" />
            <span asp-validation-for="PhoneNumber" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="RoleId" class="block font-medium text-gray-700 text-xl">Role</label>
            <select asp-for="RoleId" class="mt-1 block w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400">
                <option value="">Select Role...</option>
                @foreach(var role in Model.Roles)
                {
                    <option value="@role.RoleId">@role.RoleName</option>
                }
            </select>
            <span asp-validation-for="RoleId" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <button type="submit" class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-800 transition duration-200">
                Save Changes
            </button>
            <a asp-action="Index" class="ml-4 px-6 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition duration-200">
                Cancel
            </a>
        </div>
    </form>
</div>