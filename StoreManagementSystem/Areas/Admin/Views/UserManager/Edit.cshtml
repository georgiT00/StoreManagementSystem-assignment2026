@model UserManageViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6 text-gray-800">Edit User</h1>

    <form asp-area="Admin" asp-controller="UserManager" asp-action="Edit" method="post" class="space-y-6 bg-white p-6 rounded-lg shadow-md">
        <input type="hidden" asp-for="Id" />

        <div>
            <label asp-for="UserName" class="block text-sm font-medium text-gray-700">Username</label>
            <input asp-for="UserName" class="mt-1 block w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" />
            <span asp-validation-for="UserName" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Email" class="block text-sm font-medium text-gray-700">Email</label>
            <input asp-for="Email" type="email" class="mt-1 block w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" />
            <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Role" class="block text-sm font-medium text-gray-700">Role</label>
            <select asp-for="Role" class="mt-1 block w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400">
                <option value="Admin">Admin</option>
                <option value="Manager">Manager</option>
                <option value="User">User</option>
            </select>
            <span asp-validation-for="Role" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <button type="submit" class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-800 transition duration-200">
                Save Changes
            </button>
            <a asp-action="Index" class="ml-4 px-6 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition duration-200">
                Cancel
            </a>
        </div>
    </form>
</div>